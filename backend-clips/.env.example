PORT=4567
BACKEND_SECRET=ton-secret-pour-authentifier-les-requetes

# Optionnel : chemin vers ffmpeg avec libass (sous-titres)
# brew install ffmpeg-full
# FFMPEG_PATH=/opt/homebrew/opt/ffmpeg-full/bin/ffmpeg

OPENAI_API_KEY=sk-...

SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Rendu clips (render_subtitles.py) — perf Railway / CPU ─────────────
# Le goulot est souvent : décode 1080p + Pillow + pipe raw + x264 (voir logs ffmpeg speed~0.2x).
#
# Valeurs recommandées Railway Hobby Plan (8 vCPU / 8 GB RAM) — décommenter en prod :

# FPS de sortie max. "full" / source / off / 0 = même FPS que la source.
# 24 divise ~par 1.25 le nombre de frames traitées vs 30 fps. Recommandé prod.
RENDER_MAX_OUTPUT_FPS=24

# Preset x264 : ultrafast > superfast > veryfast > … — plus rapide = encode plus vite, qualité un peu moindre.
RENDER_LIBX264_PRESET=veryfast

# Threads x264 : 0 = auto (ffmpeg détecte les vCPU). Sur Hobby Plan (8 vCPU), 0 = optimal.
RENDER_LIBX264_THREADS=0

# CRF x264 : plus élevé = encode un peu plus vite / fichier plus petit, image un peu moins nette.
# 28 = bon compromis vitesse/qualité pour du short-form mobile (vs 20 par défaut).
RENDER_LIBX264_CRF=28

# ── Smart-crop (détection visage pass 1) ───────────────────────────────
# Intervalle de détection (en frames). Défaut 15. Augmenter = moins d'appels Haar, suivi moins fin.
# SMART_CROP_DETECT_INTERVAL=15

# Largeur max pour le downscale avant détection visage. Défaut = résolution source (pas de downscale).
# Recommandé prod : 480 (gros gain CPU, coordonnées normalisées préservées)
SMART_CROP_MAX_WIDTH=480

# ── Multi-clips (budget local vs production) ───────────────────────────
# Profil : local = peu de clips (coût dev) ; production = paliers selon la durée (3–10 clips).
# Détection auto : si RAILWAY_ENVIRONMENT est défini (Railway) → production. Sinon → local.
# Surcharge explicite (prioritaire) :
# VYLL_CLIP_PROFILE=local
# VYLL_CLIP_PROFILE=production

# Overrides réservés au profil local (plafond clips 1–3, moments prompt plafonné à 3) :
# CLIPS_MAX_PER_JOB=1
# MOMENTS_MAX=3

# En production, le nombre de clips dépend de la durée effective (source en auto, fenêtre timeline en manuel).
# Pas besoin de régler CLIPS_MAX_PER_JOB sur Railway sauf tests.

# Rendus Python en parallèle (plusieurs clips à la fois).
# 1 = moindre contention, souvent le plus rapide PAR clip sur très petite CPU.
# 2 = optimal sur Hobby Plan Railway (8 vCPU / 8 GB RAM) — gain ~1.7x sur jobs 3+ clips.
# 3+ = job total plus court si la machine tient ; sinon chaque clip reste très lent (ex. speed ffmpeg ~0.2x).
# Défaut dans le code si absent : 1
RENDER_CONCURRENCY=2

# ── YouTube (yt-dlp) : chaîne de clients + cookies Netscape ───────────────────────
# OAuth2 YouTube n'est plus supporté par yt-dlp (2024+)
# Auth YouTube : cookies Netscape uniquement (YT_DLP_COOKIES_BASE64)
# Sans cookies : pareil, souvent usable ; IP datacenter peut être bloquée.
#
# web et mweb : à éviter — YouTube exige désormais un PO Token GVS pour ces clients
# (playability status UNPLAYABLE sans token). « default » est le client fiable qui expose
# encore du 1080p en AVC — format typique avc1 id 137 (voir yt-dlp -F).
# Chaîne (ordre = priorité → fallback). yt-dlp réessaie avec le client suivant si échec.
# android en fin de chaîne : souvent ~360p seulement — éviter si YT_DLP_MIN_SOURCE_HEIGHT=1080.
# Rejet URL si hauteur source sous le palier 1080p par défaut (upload exclu) — erreur LOW_SOURCE_QUALITY.
# Exception : seuil effectif 1000 px quand cette valeur = 1080 (YouTube encode souvent ~1012 px de haut).
# Défaut code = 1080 si variable absente. Ne pas baisser si tu veux du clips « quali » uniquement.
# Déblocage d’urgence seulement : 720, ou 0 = désactive le test (déconseillé, qualité pourrie).
# YT_DLP_MIN_SOURCE_HEIGHT=1080
# Ex. si tu réintroduis web/mweb : prévoir PO Token GVS côté yt-dlp — sinon préférer default seul.
YT_DLP_YOUTUBE_CLIENT_CHAIN=default

# Cache yt-dlp — le backend passe toujours --cache-dir ici (défaut : tmp/vyrll-clips/yt-dlp-cache).
# YT_DLP_CACHE_DIR=/tmp/yt-dlp-cache

# Cookies Netscape (prod Railway)
# YT_DLP_USE_COOKIES=false   # désactive totalement l'usage de --cookies / --cookies-from-browser

# Railway : max ~32k caractères par variable. Si la base64 dépasse, couper en morceaux :
#   YT_DLP_COOKIES_BASE64_1=<premiers ~32000 caractères>
#   YT_DLP_COOKIES_BASE64_2=<suite sans espace entre les deux>
# (ne pas définir YT_DLP_COOKIES_BASE64 en même temps que _1 si tu utilises le découpage)
# YT_DLP_COOKIES_BASE64=...

# Déprécié : un seul client ou liste ; préférer YT_DLP_YOUTUBE_CLIENT_CHAIN
# YT_DLP_NO_COOKIE_PLAYER_CLIENT=android

# YOUTUBE_API_KEY=...   # optionnel : durée via API Data v3 avant yt-dlp
