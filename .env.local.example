# Copy to .env.local and fill in values (never commit .env.local).
# Supabase: Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Newer projects may use publishable key instead of anon:
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# Server-only (profiles bootstrap, admin); keep secret
SUPABASE_SERVICE_ROLE_KEY=

# Lemon Squeezy — checkout URLs (récupérer dans LS Dashboard → Produits → Share)
# NEXT_PUBLIC_LS_CREATOR_URL=https://vyrll.lemonsqueezy.com/buy/xxx-creator
# NEXT_PUBLIC_LS_STUDIO_URL=https://vyrll.lemonsqueezy.com/buy/xxx-studio

# Optional — see README.md / supabase/README.md
# YOUTUBE_API_KEY=
# OPENAI_API_KEY=
# BACKEND_URL=
# BACKEND_SECRET=
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
